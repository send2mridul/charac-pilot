# CastWeave Web - Environment Variables
# Copy to .env.local and fill in values

# ── Neon Postgres ──────────────────────────────────────────
# Connection string from Neon console (use pooled connection)
DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Auth.js (NextAuth v5) ─────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth (console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth callback base URL (auto-detected in most cases)
# Set explicitly for production: https://your-domain.com
# NEXTAUTH_URL=http://localhost:3000

# ── Python API Backend ─────────────────────────────────────
# URL of the FastAPI backend (local dev or remote)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ── Dodo Payments (Phase 3) ────────────────────────────────
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
# NEXT_PUBLIC_DODO_BUSINESS_ID=
