# CastWeave Web - Environment Variables
# Copy to .env.local and fill in values

# ── Neon Postgres ──────────────────────────────────────────
# Connection string from Neon console (use pooled connection)
DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Auth.js (NextAuth v5) ─────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth (console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth callback base URL (auto-detected in most cases)
# Set explicitly for production: https://your-domain.com
# NEXTAUTH_URL=http://localhost:3000

# ── Python API Backend ─────────────────────────────────────
# URL of the FastAPI backend (local dev or remote)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ── JWT Bridge (frontend→backend auth) ───────────────────
# Shared HS256 secret for API token signing; must match Railway API_AUTH_SECRET
API_AUTH_SECRET=

# ── Dodo Payments (billing) ──────────────────────────────
# Server-side API key for Dodo
# DODO_API_KEY=
# Webhook signature verification secret (from Dodo dashboard, starts with whsec_)
# DODO_WEBHOOK_SECRET=
# "test" or "live" — controls which Dodo API host is used
# DODO_ENVIRONMENT=test
# Product IDs (from Dodo dashboard)
# NEXT_PUBLIC_DODO_PRO_MONTHLY_PRODUCT_ID=
# NEXT_PUBLIC_DODO_PRO_YEARLY_PRODUCT_ID=
