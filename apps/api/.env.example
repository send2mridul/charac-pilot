# CastWeave API - Environment Variables
# Copy to .env and fill in values (local dev)
# On Railway, set these in the dashboard under Variables

# ── Frontend URL (CORS) ───────────────────────────────────────
# Set to your deployed Vercel frontend URL so API accepts requests from it
FRONTEND_URL=https://charac-pilot-web.vercel.app

# ── Storage ───────────────────────────────────────────────────
# On Railway, mount a volume at /data and set this:
# CASTWEAVE_STORAGE_PATH=/data
# Locally, leave unset (defaults to apps/api/storage/)

# ── Azure Video Indexer ───────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_VIDEO_INDEXER_ACCOUNT_NAME=
AZURE_VIDEO_INDEXER_ACCOUNT_ID=
AZURE_VIDEO_INDEXER_REGION=

# ── ElevenLabs TTS ────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Gemini (draft line generation) ────────────────────────────
GEMINI_API_KEY=

# ── OpenAI (draft line generation, optional) ──────────────────
# OPENAI_API_KEY=

# ── Import / processing limits ────────────────────────────────
# CASTWEAVE_MAX_UPLOAD_MB=500          # max upload file size in MB
# CASTWEAVE_MAX_DURATION_SEC=1800      # max media duration (30 min default)
# CASTWEAVE_MAX_CONCURRENT_JOBS=1      # max parallel processing threads
# CASTWEAVE_EPISODE_MEDIA_MAX_SEC=5400 # wall-clock timeout for pipeline

# ── Whisper ASR ──────────────────────────────────────────────
# Production (Railway): tiny/small to save memory
# Local/dev: base/medium for better quality
# WHISPER_MODEL_SIZE=tiny       # default detect model
# WHISPER_MODEL_SIZE_EN=tiny    # English tier
# WHISPER_MODEL_SIZE_HI=small   # Hindi tier
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# ── Cloudflare R2 (object storage) ───────────────────────────
# When R2 vars are set, media is stored in R2 and Railway disk is temp-only.
# When unset (local dev), all media stays on local disk — no R2 needed.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_UPLOADS=castweave-uploads
# R2_BUCKET_ARTIFACTS=castweave-artifacts
# R2_ENDPOINT=                   # optional, defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# ── FFmpeg (optional, auto-detected from PATH) ────────────────
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
