# Copy to .env and set your key (never commit .env)
ELEVENLABS_API_KEY=
# Optional override (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Azure AI Video Indexer (optional primary import path; local ASR remains fallback)
# Use `az login` locally. In production use Managed Identity or service principal env vars.
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=castweave-rg
# AZURE_VIDEO_INDEXER_ACCOUNT_NAME=castweave-vi
# AZURE_VIDEO_INDEXER_ACCOUNT_ID=
# AZURE_VIDEO_INDEXER_REGION=centralindia
# AZURE_STORAGE_ACCOUNT_NAME=castweavevistorage
# Optional ARM API version override (default 2025-04-01)
# AZURE_VIDEO_INDEXER_ARM_API_VERSION=2025-04-01
# AZURE_VIDEO_INDEXER_POLL_INTERVAL_SEC=10
# AZURE_VIDEO_INDEXER_POLL_TIMEOUT_SEC=3600
